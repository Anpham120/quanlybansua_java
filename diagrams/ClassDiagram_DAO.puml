@startuml ClassDiagram_DAO

' =====================================================
'  SO DO LOP - TANG DAO (7 lop: 1 ket noi + 6 truy van)
'  He thong Quan ly Ban Sua
' =====================================================

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 45
skinparam shadowing false

class DatabaseConnection {
    - {static} HOST : String
    - {static} PORT : String
    - {static} TEN_CSDL : String
    - {static} TAI_KHOAN : String
    - {static} MAT_KHAU : String
    - {static} URL : String
    - {static} URL_CSDL : String
    __
    + {static} layKetNoi() : Connection
    + {static} dongKetNoi(conn : Connection) : void
    + {static} khoiTaoDatabase() : void
    - {static} taoCSDL() : void
    - {static} taoBang() : void
    - {static} themDuLieuMau() : void
}

class TaiKhoanDAO {
    + dangNhap(tenDN : String, mk : String) : TaiKhoan
    + layTatCa() : List<TaiKhoan>
    + layTKChuaLienKet(idTKHienTai : int) : List<TaiKhoan>
    + timKiem(tuKhoa : String) : List<TaiKhoan>
    + kiemTraTrungTenDN(tenDN : String, idBoQua : int) : boolean
    + them(tk : TaiKhoan) : boolean
    + capNhat(tk : TaiKhoan) : boolean
    + xoa(id : int) : boolean
    + xoaCoLienKet(id : int) : boolean
    + kiemTraLienKetNhanVien(idTK : int) : boolean
    + doiMatKhau(idTK : int, mkCu : String, mkMoi : String) : boolean
}

class NhanVienDAO {
    + layTatCa() : List<NhanVien>
    + timKiem(tuKhoa : String) : List<NhanVien>
    + kiemTraTrungSDT(sdt : String, idBoQua : int) : boolean
    + them(nv : NhanVien) : boolean
    + capNhat(nv : NhanVien) : boolean
    + xoa(id : int) : boolean
    + xoaCoLienKet(id : int) : boolean
    + kiemTraLienKetHoaDon(idNV : int) : boolean
    - docNhanVien(rs : ResultSet) : NhanVien
    - ganGiaTri(ps : PreparedStatement, nv : NhanVien) : void
}

class SanPhamDAO {
    + layTatCa() : List<SanPham>
    + timTheoTen(tuKhoa : String) : List<SanPham>
    + locTheoLoai(loai : String) : List<SanPham>
    + timKiem(tuKhoa : String, loai : String) : List<SanPham>
    + layDanhSachLoai() : List<String>
    + kiemTraTrung(tenSP : String, idBoQua : int) : boolean
    + them(sp : SanPham) : boolean
    + capNhat(sp : SanPham) : boolean
    + xoa(id : int) : boolean
    + xoaCoLienKet(id : int) : boolean
    + truTonKho(idSP : int, soLuong : int) : boolean
    + kiemTraLienKetHoaDon(idSP : int) : boolean
    + demSapHetHan(soNgay : int) : int
    + demHetHang() : int
    - docSanPham(rs : ResultSet) : SanPham
    - ganGiaTri(ps : PreparedStatement, sp : SanPham) : void
}

class KhachHangDAO {
    + layTatCa() : List<KhachHang>
    + timKiem(tuKhoa : String) : List<KhachHang>
    + kiemTraTrungSDT(sdt : String, idBoQua : int) : boolean
    + them(kh : KhachHang) : boolean
    + capNhat(kh : KhachHang) : boolean
    + xoa(id : int) : boolean
    + xoaCoLienKet(id : int) : boolean
    + kiemTraLienKetHoaDon(idKH : int) : boolean
    + congDiem(idKH : int, soDiem : int) : void
    - docKhachHang(rs : ResultSet) : KhachHang
}

class HoaDonDAO {
    + taoHoaDon(idNV : int, idKH : int, tongTien : double, ds : List<ChiTietHoaDon>) : int
    + layIdNhanVienTheoTaiKhoan(idTK : int) : int
    + layTatCa() : List<Object[]>
    + layChiTiet(idHD : int) : List<Object[]>
    + loc(tuNgay : String, denNgay : String, sdtKH : String) : List<Object[]>
    + doanhThuHomNay() : double
    + doanhThuThangNay() : double
    + soHoaDonHomNay() : int
    + doanhThu7Ngay() : List<Object[]>
    + doanhThuTheoKhoang(tu : Date, den : Date) : double
    + soHoaDonTheoKhoang(tu : Date, den : Date) : int
    + doanhThuTheoKhoangNgay(tu : Date, den : Date) : List<Object[]>
    + topSanPham(n : int) : List<Object[]>
    + topSanPhamTheoKhoang(n : int, tu : Date, den : Date) : List<Object[]>
}

' === QUAN HE ===
TaiKhoanDAO ..> DatabaseConnection : dung
NhanVienDAO ..> DatabaseConnection : dung
SanPhamDAO ..> DatabaseConnection : dung
KhachHangDAO ..> DatabaseConnection : dung
HoaDonDAO ..> DatabaseConnection : dung

note bottom of HoaDonDAO
  taoHoaDon() dung
  JDBC Transaction
  (setAutoCommit=false)
end note

@enduml
