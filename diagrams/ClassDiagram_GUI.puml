@startuml ClassDiagram_GUI

' =====================================================
'  SO DO LOP - TANG GUI + UTILS + ENTRY
'  He thong Quan ly Ban Sua  (BAM SAT 100% CODE)
' =====================================================

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 45
skinparam shadowing false

' === ENTRY ===
class Main {
    + {static} main(args : String[]) : void
}

' === GUI ===
class LoginFrame <<JFrame>> {
    - txtTenDangNhap : JTextField
    - txtMatKhau : JPasswordField
    - btnDangNhap : JButton
    - lblThongBao : JLabel
    __
    + LoginFrame()
    - khoiTaoGiaoDien() : void
    - xuLyDangNhap() : void
}

class MainFrame <<JFrame>> {
    - taiKhoanHienTai : TaiKhoan
    - panelNoiDung : JPanel
    - cardLayout : CardLayout
    - nutDangChon : JPanel
    __
    + MainFrame(taiKhoan : TaiKhoan)
    - khoiTaoGiaoDien() : void
    - taoThanhMenu() : JPanel
    - taoMucMenu(tieuDe : String, tenThe : String) : JPanel
    - chonNutMenu(panel : JPanel) : void
    - taoHeader() : JPanel
}

class BanHangPanel <<JPanel>> {
    - sanPhamDAO : SanPhamDAO
    - khachHangDAO : KhachHangDAO
    - hoaDonDAO : HoaDonDAO
    - gioHang : List<ChiTietHoaDon>
    - idNhanVien : int
    - bangSP : JTable
    - bangGioHang : JTable
    __
    + BanHangPanel(taiKhoan : TaiKhoan)
    - timKiemSanPham() : void
    - themVaoGio() : void
    - capNhatSoLuong() : void
    - xoaKhoiGio() : void
    - thanhToan() : void
    - taiDanhSachKhachHang() : void
    - hienFormDangKyKH() : void
    - tinhTongTien() : void
}

class SanPhamPanel <<JPanel>> {
    - vaiTro : String
    - sanPhamDAO : SanPhamDAO
    - bangSanPham : JTable
    - modelBang : DefaultTableModel
    __
    + SanPhamPanel(vaiTro : String)
    - taiDuLieu() : void
    - themSanPham() : void
    - suaSanPham() : void
    - xoaSanPham() : void
    - lamMoi() : void
    - timKiem() : void
}

class KhachHangPanel <<JPanel>> {
    - vaiTro : String
    - khachHangDAO : KhachHangDAO
    - bangKH : JTable
    - modelBang : DefaultTableModel
    __
    + KhachHangPanel(vaiTro : String)
    - taiDuLieu() : void
    - themKhachHang() : void
    - suaKhachHang() : void
    - xoaKhachHang() : void
    - lamMoi() : void
    - timKiem() : void
}

class NhanVienPanel <<JPanel>> {
    - vaiTro : String
    - nhanVienDAO : NhanVienDAO
    - taiKhoanDAO : TaiKhoanDAO
    - bangNV : JTable
    - modelBang : DefaultTableModel
    __
    + NhanVienPanel(vaiTro : String)
    - taiDuLieu() : void
    - taiDSTaiKhoan() : void
    - themNhanVien() : void
    - suaNhanVien() : void
    - xoaNhanVien() : void
    - lamMoi() : void
}

class HoaDonPanel <<JPanel>> {
    - hoaDonDAO : HoaDonDAO
    - tableHD : JTable
    - tableChiTiet : JTable
    __
    + HoaDonPanel()
    - taiDuLieu() : void
    - locHoaDon() : void
    - hienChiTiet(idHD : int) : void
}

class ThongKePanel <<JPanel>> {
    - hoaDonDAO : HoaDonDAO
    - sanPhamDAO : SanPhamDAO
    __
    + ThongKePanel()
    - capNhatKPI() : void
    - capNhatBieuDo() : void
    - capNhatTopSP() : void
    - xuatCSV() : void
}

class TaiKhoanPanel <<JPanel>> {
    - taiKhoanDAO : TaiKhoanDAO
    - bangTK : JTable
    - modelBang : DefaultTableModel
    __
    + TaiKhoanPanel()
    - taiDuLieu() : void
    - themTaiKhoan() : void
    - suaTaiKhoan() : void
    - xoaTaiKhoan() : void
    - lamMoi() : void
}

class DoiMatKhauDialog <<JDialog>> {
    - idTaiKhoan : int
    - taiKhoanDAO : TaiKhoanDAO
    - txtMatKhauCu : JPasswordField
    - txtMatKhauMoi : JPasswordField
    - txtXacNhan : JPasswordField
    __
    + DoiMatKhauDialog(parent : JFrame, idTaiKhoan : int)
    - khoiTaoGiaoDien() : void
    - doiMatKhau() : void
    - taoLabel(text : String) : JLabel
}

' === UTILS ===
class UIConstants {
    + {static} PRIMARY : Color
    + {static} PRIMARY_DARK : Color
    + {static} PRIMARY_LIGHT : Color
    + {static} SUCCESS : Color
    + {static} DANGER : Color
    + {static} WARNING : Color
    + {static} INFO : Color
    + {static} BG_MAIN : Color
    + {static} BG_SIDEBAR : Color
    + {static} BG_SIDEBAR_HOVER : Color
    + {static} BG_SIDEBAR_ACTIVE : Color
    + {static} BG_CARD : Color
    + {static} TEXT_DARK : Color
    + {static} TEXT_LIGHT : Color
    + {static} BORDER_COLOR : Color
    + {static} FONT_TITLE : Font
    + {static} FONT_SUBTITLE : Font
    + {static} FONT_LABEL : Font
    + {static} FONT_INPUT : Font
    + {static} FONT_BUTTON : Font
    + {static} FONT_TABLE_HEADER : Font
    + {static} FONT_TABLE : Font
    + {static} FONT_MENU : Font
    + {static} FONT_SMALL : Font
    + {static} SIDEBAR_WIDTH : int
    + {static} HEADER_HEIGHT : int
    + {static} MENU_ITEM_HEIGHT : int
    + {static} BUTTON_SIZE : Dimension
    __
    + {static} createStyledButton(text : String, bgColor : Color) : JButton
}

class AppConstants {
    + {static} TIEN_MOI_DIEM : int
    + {static} DIEM_BAC : int
    + {static} DIEM_VANG : int
    + {static} DIEM_KIM_CUONG : int
    + {static} GIAM_BAC : double
    + {static} GIAM_VANG : double
    + {static} GIAM_KIM_CUONG : double
    + {static} FORMAT_TIEN : DecimalFormat
    + {static} TEN_DN_MIN : int
    + {static} MAT_KHAU_MIN : int
    + {static} TUOI_LAM_VIEC_MIN : int
    + {static} VAI_TRO_QUAN_LY : String
    + {static} VAI_TRO_NHAN_VIEN : String
}

class InputFilter {
    + {static} applyDigitsOnly(field : JTextField) : void
    + {static} applyDigitsAndDot(field : JTextField) : void
}

class TableHelper {
    - {static} ZEBRA_EVEN : Color
    - {static} ZEBRA_ODD : Color
    __
    + {static} applyStyle(table : JTable) : void
    + {static} createZebraRenderer(centerCols : int[], rightCols : int[]) : DefaultTableCellRenderer
    + {static} createReadOnlyModel(columns : String[]) : DefaultTableModel
    + {static} createFormLabel(text : String) : JLabel
    + {static} createSmallButton(text : String, bgColor : Color) : JButton
}

' === QUAN HE ===
Main ..> LoginFrame : tao
LoginFrame ..> MainFrame : mo khi dang nhap thanh cong
MainFrame *-- BanHangPanel
MainFrame *-- SanPhamPanel
MainFrame *-- KhachHangPanel
MainFrame *-- NhanVienPanel
MainFrame *-- HoaDonPanel
MainFrame *-- ThongKePanel
MainFrame *-- TaiKhoanPanel

LoginFrame ..> TaiKhoanDAO : dung
BanHangPanel ..> HoaDonDAO : dung
BanHangPanel ..> SanPhamDAO : dung
BanHangPanel ..> KhachHangDAO : dung
SanPhamPanel ..> SanPhamDAO : dung
KhachHangPanel ..> KhachHangDAO : dung
NhanVienPanel ..> NhanVienDAO : dung
NhanVienPanel ..> TaiKhoanDAO : dung
HoaDonPanel ..> HoaDonDAO : dung
ThongKePanel ..> HoaDonDAO : dung
ThongKePanel ..> SanPhamDAO : dung
TaiKhoanPanel ..> TaiKhoanDAO : dung
DoiMatKhauDialog ..> TaiKhoanDAO : dung

@enduml
